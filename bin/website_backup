#!/usr/bin/env php
<?php

require __DIR__ . '/../vendor/autoload.php';

use Symfony\Component\Console\Application;
use App\Command\BackupLocalCommand;
use App\Command\BackupS3Command;
use App\Command\InstallCommand;
use App\Command\HealthcheckCommand;
use App\Command\UnpackCommand;

$application = new Application('Website Backup');
$application->setVersion('0.0.1');

// Config and services setup will happen here later.

$application->add(new BackupLocalCommand());
$application->add(new BackupS3Command());
$application->add(new InstallCommand());
$application->add(new HealthcheckCommand());
$application->add(new UnpackCommand());

$application->run();
